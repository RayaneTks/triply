# =============================================================================
# Next.js (frontend/triplydev/) — conteneur tri-app (Docker) ou `npm run dev`
# =============================================================================
# Copié en `.env` par `make up` / `make init` si absent.
# Les clés sensibles ci-dessous sont lues côté serveur (routes app/api/*) sauf NEXT_PUBLIC_*.

# --- API Laravel
# Navigateur : même origine, préfixe /api/v1 via proxy Next → tri-api
NEXT_PUBLIC_BACKEND_API_URL=/api/v1
# Serveur Next (routes API, SSR) : nom du service Docker Nginx
BACKEND_API_BASE_URL=http://tri-api/api/v1
BACKEND_PROXY_TARGET=http://tri-api

# --- Auth navigateur
NEXT_PUBLIC_AUTH_STORAGE_MODE=session

# --- Carte Mapbox (client + route /api/geocode/reverse)
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- URL du site (SEO, layout À propos, etc.)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:5173

# --- OpenAI (route assistant, etc.)
OPENAI_API_KEY=

# --- Amadeus (vols / hôtels — routes app/api/*)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# --- Google Places (avis lieux — route place-reviews)
GOOGLE_PLACES_API_KEY=
