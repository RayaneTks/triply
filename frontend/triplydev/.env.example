# =============================================================================
# Frontend SPA (frontend/triplydev)
# =============================================================================
# Variables front uniquement. Aucun secret backend ici.

# API Laravel cible pour le proxy Express (server.ts)
LARAVEL_API_URL=http://127.0.0.1:8000
# En Docker: compose.dev.yaml force déjà LARAVEL_API_URL=http://tri-api:80

# Préfixe API côté navigateur
VITE_API_BASE_URL=/api/v1

# Token Mapbox public
VITE_MAPBOX_TOKEN=
