# =============================================================================
# Next.js (frontend/triplydev/) — conteneur tri-app (Docker) ou `npm run dev`
# =============================================================================
# Copié en `.env` par `make up` / `make init` si absent.
# OpenAI, Amadeus, Google Places : uniquement dans backend/.env (routes Laravel /api/v1/integrations/*).

# --- API Laravel
# Navigateur : préfixe relatif → Next rewrite (next.config.ts) vers tri-api en Docker.
# URL absolue possible : si vous ne mettez que l’origine (ex. http://127.0.0.1:8000), /api/v1 est ajouté automatiquement.
NEXT_PUBLIC_BACKEND_API_URL=/api/v1
# Serveur Next (SSR / rewrites) : nom du service Docker Nginx
BACKEND_API_BASE_URL=http://tri-api/api/v1
BACKEND_PROXY_TARGET=http://tri-api

# --- Auth navigateur
NEXT_PUBLIC_AUTH_STORAGE_MODE=session

# --- Carte Mapbox (client + route serveur /api/geocode/reverse — exception volontaire côté Next)
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- URL du site (SEO, layout À propos, etc.)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:5173
