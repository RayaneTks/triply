APP_NAME=Triply
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost:5173

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

#Générée_avec_la_commande_php artisan key:generate
APP_KEY=

# ---- CONFIG BDD POSTGRES (Docker) ----
DB_CONNECTION=pgsql
DB_HOST=tri-postgres
DB_PORT=5432
DB_DATABASE=TriplyDB
DB_USERNAME=laravel
DB_PASSWORD=api_password
DB_ROOT_PASSWORD=api_root_password

MAIL_MAILER=log
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Conversion de devise (fallback backend si Amadeus ne renvoie pas EUR)
CURRENCY_RATES_BASE_URL=https://api.frankfurter.app
CURRENCY_RATES_CACHE_TTL_MINUTES=360
CURRENCY_RATES_TIMEOUT_SECONDS=4
