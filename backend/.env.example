APP_NAME=Triply
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost:5173

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

#Générée_avec_la_commande_php artisan key:generate
APP_KEY=

# ---- CONFIG BDD POSTGRES (Docker) ----
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=TriplyDB
DB_USERNAME=backend
DB_PASSWORD=backend

MAIL_MAILER=log
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME="${APP_NAME}"
