# =============================================================================
# Laravel (backend/) — utilisé par tri-php-fpm et tri-workspace (Docker)
# =============================================================================
# Copié en `.env` par `make up` / `make init` si absent. Puis : `php artisan key:generate`
# Les variables DB_* doivent correspondre à la racine `.env` (compose) et à tri-postgres.

# --- Application
APP_NAME=Triply
APP_ENV=local
APP_DEBUG=true
# URL publique de l’API (Nginx tri-api, port hôte 8000)
APP_URL=http://127.0.0.1:8000

# Générer avec : php artisan key:generate
APP_KEY=

# --- Base de données (Docker : hôte tri-postgres)
DB_CONNECTION=pgsql
DB_HOST=tri-postgres
DB_PORT=5432
DB_DATABASE=TriplyDB
DB_USERNAME=laravel
DB_PASSWORD=api_password
DB_ROOT_PASSWORD=api_root_password

# --- Cache / session / queue (dev simple dans Docker)
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# --- Redis (service tri-redis) — décommenter pour utiliser Redis
# REDIS_HOST=tri-redis
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# CACHE_STORE=redis
# SESSION_DRIVER=redis

# --- CORS (origines du front Next en Docker : port hôte 5173)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000

# --- Sanctum (cookies / SPA sur les mêmes origines)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# --- Mail (dev)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Conversion devises (fallback si Amadeus ne renvoie pas EUR)
CURRENCY_RATES_BASE_URL=https://api.frankfurter.app
CURRENCY_RATES_CACHE_TTL_MINUTES=360
CURRENCY_RATES_TIMEOUT_SECONDS=4

# --- Swagger (optionnel)
# L5_SWAGGER_CONST_HOST=http://127.0.0.1:8000

# --- Intégrations (clés uniquement côté backend — SPA Vite racine et Next triplydev passent par /api/v1/*)
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# AMADEUS_BASE_URL=https://test.api.amadeus.com
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# GOOGLE_PLACES_API_KEY=
