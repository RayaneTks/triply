# =============================================================================
# Vite + Express (rework-front/) — `npm run dev` (port 3000 par défaut)
# =============================================================================
# Copier en `.env` à la main si besoin : ce dossier n’est pas encore branché sur make Docker.

# --- Gemini (injecté côté build via vite.config — ne pas committer de vraie clé)
GEMINI_API_KEY=

# --- Carte Mapbox (composant Map — VITE_*)
VITE_MAPBOX_TOKEN=

# --- Amadeus (recherche vol/hôtel quand branché)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# --- URL publique de l’applet (liens absolus, callbacks)
APP_URL=http://127.0.0.1:3000
