# =============================================================================
# Racine du dépôt — interpolation Docker Compose (compose.dev.yaml)
# =============================================================================
# Copié en `.env` par `make up` / `make init` (scripts/ensure-dev-env.cjs) si absent.
# Les valeurs DB_* doivent rester identiques à backend/.env pour Postgres + Laravel.

# --- Port Postgres sur l’hôte (éviter conflit si une autre instance tourne)
POSTGRES_PORT=5432

# --- Base PostgreSQL (services tri-postgres ; identique à backend/.env)
DB_DATABASE=TriplyDB
DB_USERNAME=laravel
DB_PASSWORD=api_password
DB_ROOT_PASSWORD=api_root_password

# --- pgAdmin (http://127.0.0.1:8080)
PGADMIN_DEFAULT_EMAIL=contact@triply.ovh
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_CONFIG_SERVER_MODE=False

# =============================================================================
# SPA Vite (racine : src/, server.ts) — service Docker tri-app, chargé via ce .env
# =============================================================================
# Backend Laravel : URL atteinte par le proxy Express (server.ts → /api/v1/*)
# et par le proxy de dev Vite (vite.config.ts → /api/*) si vous lancez `vite` seul.
# En Docker dev : http://tri-api:80 (réseau triply-development).
# Hors Docker  : http://127.0.0.1:8000.
LARAVEL_API_URL=http://tri-api:80

# Préfixe API côté navigateur (recommandé : /api/v1). Le proxy Express relaie vers LARAVEL_API_URL.
# Si vous mettez une URL absolue sans chemin (ex. http://127.0.0.1:8000), /api/v1 est ajouté automatiquement.
VITE_API_BASE_URL=/api/v1

# Mapbox (seul fournisseur dont le jeton est prévu côté navigateur — affichage des cartes).
# OpenAI, Amadeus, Google Places : exclusivement dans backend/.env (jamais VITE_* / NEXT_PUBLIC_* pour ces secrets).
VITE_MAPBOX_TOKEN=

# --- Optionnel : build PHP (tri-php-fpm / tri-workspace)
# UID=1000
# GID=1000
# XDEBUG_ENABLED=true
# XDEBUG_HOST=host.docker.internal
